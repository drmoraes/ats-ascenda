{
  "realm": "ats",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "RECRUITER" },
      { "name": "HIRING_MANAGER" },
      { "name": "TENANT_ADMIN" }
    ]
  },
  "clients": [
    {
      "clientId": "ats-backend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocolMappers": [
        {
          "name": "audience-ats-backend",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "ats-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "recrutador@demo.com",
      "email": "recrutador@demo.com",
      "firstName": "Recrutador",
      "lastName": "Demo",
      "enabled": true,
      "emailVerified": true,
      "attributes": {
        "tenant_id": ["11111111-1111-1111-1111-111111111111"]
      },
      "credentials": [
        { "type": "password", "value": "demo1234", "temporary": false }
      ],
      "realmRoles": ["RECRUITER"]
    }
  ]
}
