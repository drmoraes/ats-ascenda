# ATS ASCENDA — variáveis de ambiente (nunca commitar o .env real)

# --- App ---
NODE_ENV=development
PORT=3000

# --- Banco de dados ---
DATABASE_URL="postgresql://ats:senha@localhost:5432/ats?schema=public"

# --- Redis (BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- AWS / S3 ---
AWS_REGION=sa-east-1
S3_RESUMES_BUCKET=ats-ascenda-resumes
# Em produção: usar IAM Role (não chaves). Chaves apenas em dev local:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Provedor de IA (parsing) ---
# Abstração AIProvider — apenas a chave muda o adapter concreto.
AI_PARSER_API_BASE_URL=https://api.anthropic.com/v1
AI_PARSER_API_KEY=
AI_PARSER_MODEL=claude-sonnet-5
AI_PARSER_TIMEOUT_MS=30000

# --- Auth: Keycloak (usuários internos: recrutador/gestor) ---
KEYCLOAK_ISSUER=https://auth.ats-ascenda.com/realms/ats
KEYCLOAK_JWKS_URL=https://auth.ats-ascenda.com/realms/ats/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=ats-backend
KEYCLOAK_TENANT_CLAIM=tenant_id

# --- Auth: token de sessão do candidato (emitido pelo backend) ---
# Gerar com: openssl rand -hex 32
CANDIDATE_JWT_SECRET=
CANDIDATE_JWT_ISSUER=ats-ascenda-candidate
CANDIDATE_TOKEN_TTL_SECONDS=3600

# --- Notificações (opcionais; obrigatórias por canal ao enviar) ---
# E-mail (ex.: SendGrid/SES via API HTTP)
EMAIL_API_BASE_URL=
EMAIL_API_KEY=
EMAIL_FROM=
# WhatsApp Cloud API
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
NOTIFICATION_TIMEOUT_MS=15000
